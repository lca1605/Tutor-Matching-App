<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyApp.Views.TutorCardView">

  <UserControl.Styles>
    <Style Selector="Border.tag">
      <Setter Property="Background" Value="#F0EDFF"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="10,4"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*,Auto" Cursor="Hand">

    <!-- Ảnh gia sư -->
    <Border Grid.Row="0" ClipToBounds="True">
      <Panel>
        <!-- Placeholder khi chưa có ảnh -->
        <Border Name="ImagePlaceholder"
                Background="#E8E4FF">
          <TextBlock Text="📷" FontSize="48"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Opacity="0.3"/>
        </Border>
        <!-- Ảnh thật -->
        <Image Name="TutorImage"
               Stretch="UniformToFill"
               IsVisible="False"/>
        <!-- Gradient overlay phía dưới ảnh -->
        <Border VerticalAlignment="Bottom" Height="80">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
              <GradientStop Color="Transparent" Offset="0"/>
              <GradientStop Color="#30000000" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>
      </Panel>
    </Border>

    <!-- Thông tin gia sư -->
    <Border Grid.Row="1" Padding="20,16,20,20">
      <StackPanel Spacing="0">

        <!-- Tên + Rating -->
        <Grid Margin="0,0,0,4">
          <StackPanel>
            <TextBlock Name="TutorNameText"
                       Text="Đang tải..."
                       FontSize="20" FontWeight="Bold"
                       Foreground="#1A1A2E"/>
            <TextBlock Name="TutorTitleText"
                       Text=""
                       FontSize="13" Foreground="#7C6FCD"
                       FontWeight="SemiBold"/>
          </StackPanel>
          <!-- Rating -->
          <StackPanel HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="4"
                        HorizontalAlignment="Right">
              <TextBlock Text="⭐" FontSize="16"/>
              <TextBlock Name="RatingText"
                         Text="--"
                         FontSize="16" FontWeight="Bold"
                         Foreground="#1A1A2E"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Name="ReviewCountText"
                       Text="-- reviews"
                       FontSize="11" Foreground="#AAAACC"
                       HorizontalAlignment="Right"/>
          </StackPanel>
        </Grid>

        <Border Height="1" Background="#F0F0F0" Margin="0,10,0,10"/>

        <!-- Info rows -->
        <StackPanel Spacing="6" Margin="0,0,0,10">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="🎓" FontSize="13"/>
            <TextBlock Name="DegreeText" Text="--"
                       FontSize="13" Foreground="#444466"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="💼" FontSize="13"/>
            <TextBlock Name="ExperienceText" Text="--"
                       FontSize="13" Foreground="#444466"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="💰" FontSize="13"/>
            <TextBlock Name="PriceText" Text="--"
                       FontSize="13" Foreground="#444466"
                       VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="📍" FontSize="13"/>
            <TextBlock Name="ModeText" Text="--"
                       FontSize="13" Foreground="#444466"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>

        <!-- Môn dạy tags -->
        <WrapPanel Name="SubjectTagPanel" Margin="0,0,0,12"/>

        <!-- Mô tả -->
        <TextBlock Name="DescriptionText"
                   Text=""
                   FontSize="13" Foreground="#666688"
                   TextWrapping="Wrap"
                   MaxLines="2"
                   TextTrimming="CharacterEllipsis"/>

      </StackPanel>
    </Border>

  </Grid>
</UserControl>