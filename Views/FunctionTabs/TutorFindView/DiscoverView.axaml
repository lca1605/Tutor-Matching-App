<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyApp.Views.DiscoverView">

  <UserControl.Styles>
    <Style Selector="Button.nav">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </UserControl.Styles>

  <Grid Background="#F7F8FC" RowDefinitions="Auto,*">

    <!-- Sub-header -->
    <Grid Grid.Row="0" Margin="20,14,20,10">
      <StackPanel VerticalAlignment="Center">
        <TextBlock Name="CardCountText"
                   Text="Đang tải..."
                   FontSize="18" FontWeight="Bold"
                   Foreground="#111122"/>
        <TextBlock Name="CardSubText"
                   Text="Gia sư phù hợp với bạn"
                   FontSize="12" Foreground="#9090A8"/>
      </StackPanel>

      <!-- Filter pill -->
      <Border HorizontalAlignment="Right" VerticalAlignment="Center"
              CornerRadius="20" Background="#FFFFFF"
              BorderBrush="#DDDDF0" BorderThickness="1">
        <Button Classes="nav" Padding="12,7" Click="OnFilterClick">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <StackPanel Spacing="3" VerticalAlignment="Center">
              <Rectangle Width="14" Height="1.5" Fill="#7C6FCD" RadiusX="1" RadiusY="1"/>
              <Rectangle Width="10" Height="1.5" Fill="#7C6FCD" RadiusX="1" RadiusY="1"
                         HorizontalAlignment="Center"/>
              <Rectangle Width="6"  Height="1.5" Fill="#7C6FCD" RadiusX="1" RadiusY="1"
                         HorizontalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Lọc" FontSize="13" FontWeight="SemiBold"
                       Foreground="#333344" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Border>
    </Grid>

    <!-- Card -->
    <Border Grid.Row="1" Margin="20,0,20,16"
            CornerRadius="18" Background="#FFFFFF"
            BorderBrush="#EBEBF0" BorderThickness="1"
            ClipToBounds="True">
      <ContentControl Name="CardHost"/>
    </Border>

    <!-- Filter overlay — chỉ phủ lên DiscoverView -->
    <Border Grid.Row="0" Grid.RowSpan="2"
            Name="FilterOverlay" IsVisible="False"
            Background="#70000000">
      <ContentControl Name="FilterHost" VerticalAlignment="Bottom"/>
    </Border>

  </Grid>
</UserControl>