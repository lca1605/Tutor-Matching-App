<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyApp.Views.HomeView">

  <UserControl.Styles>
    <Style Selector="Button.nav">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.nav:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="56,*,64">

    <!-- ══ TOP BAR ══════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="#FFFFFF"
            BorderBrush="#EBEBF0"
            BorderThickness="0,0,0,1"
            Padding="16,0">
      <Grid ColumnDefinitions="40,*,40">

        <!-- Hamburger -->
        <Button Grid.Column="0" Classes="nav"
                Width="40" Height="40"
                VerticalAlignment="Center"
                Click="OnMenuClick">
          <StackPanel Spacing="4" VerticalAlignment="Center"
                      HorizontalAlignment="Center">
            <Rectangle Width="18" Height="1.5" Fill="#111122" RadiusX="1" RadiusY="1"/>
            <Rectangle Width="14" Height="1.5" Fill="#111122" RadiusX="1" RadiusY="1"
                       HorizontalAlignment="Left"/>
            <Rectangle Width="18" Height="1.5" Fill="#111122" RadiusX="1" RadiusY="1"/>
          </StackPanel>
        </Button>

        <!-- Title — thay đổi theo tab -->
        <TextBlock Name="TopBarTitle"
                   Grid.Column="1"
                   Text="Tìm Gia Sư"
                   FontSize="16" FontWeight="Bold"
                   Foreground="#111122"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- Avatar -->
        <Button Grid.Column="2" Classes="nav"
                Width="40" Height="40"
                VerticalAlignment="Center"
                Click="OnProfileClick">
          <Border Width="32" Height="32" CornerRadius="16"
                  Background="#F0EDFF" HorizontalAlignment="Center">
            <Panel>
              <Border Name="AvatarBorder" Width="32" Height="32"
                      CornerRadius="16" IsVisible="False" ClipToBounds="True">
                <Image Name="AvatarImage" Stretch="UniformToFill"/>
              </Border>
              <TextBlock Name="AvatarInitial"
                         Text="?" FontSize="14" FontWeight="Bold"
                         Foreground="#7C6FCD"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Panel>
          </Border>
        </Button>

      </Grid>
    </Border>

    <!-- ══ BODY — swap theo tab ══════════════════════════════════════════════ -->
    <ContentControl Name="BodyHost" Grid.Row="1"/>

    <!-- ══ BOTTOM NAV ════════════════════════════════════════════════════════ -->
    <Border Grid.Row="2"
            Background="#FFFFFF"
            BorderBrush="#EBEBF0"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,*,*,*" Height="64">

        <!-- Trang Chủ -->
        <Button Grid.Column="0" Classes="nav"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Click="OnNavHomeClick">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center" Spacing="4">
            <Canvas Width="22" Height="20" HorizontalAlignment="Center">
              <Polygon Name="NavHomeIcon"
                       Points="11,1 21,10 18,10 18,19 13,19 13,13 9,13 9,19 4,19 4,10 1,10"
                       Fill="#7C6FCD"/>
            </Canvas>
            <TextBlock Name="NavHomeText" Text="Trang Chủ"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#7C6FCD"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- Tin Nhắn -->
        <Button Grid.Column="1" Classes="nav"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Click="OnNavMessageClick">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center" Spacing="4">
            <Grid Width="22" Height="20" HorizontalAlignment="Center">
              <Border Name="NavMsgIcon"
                      Width="20" Height="16"
                      CornerRadius="4"
                      BorderBrush="#9090A8"
                      BorderThickness="1.8"
                      VerticalAlignment="Top"/>
              <Border Name="MsgBadge" IsVisible="False"
                      Background="#EF4444" CornerRadius="6"
                      MinWidth="14" Height="14"
                      HorizontalAlignment="Right" VerticalAlignment="Top"
                      Margin="0,-4,-4,0" Padding="3,0">
                <TextBlock Name="MsgBadgeText" Text="0"
                           FontSize="8" Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Border>
            </Grid>
            <TextBlock Name="NavMsgText" Text="Tin Nhắn"
                       FontSize="10" Foreground="#9090A8"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- Thông Báo -->
        <Button Grid.Column="2" Classes="nav"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Click="OnNavNotifyClick">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center" Spacing="4">
            <Grid Width="22" Height="20" HorizontalAlignment="Center">
              <StackPanel VerticalAlignment="Center" Spacing="0">
                <Border Name="NavNotiIcon"
                        Width="16" Height="13"
                        CornerRadius="8,8,0,0"
                        BorderBrush="#9090A8"
                        BorderThickness="1.8"
                        HorizontalAlignment="Center"/>
                <Rectangle Width="6" Height="2" Fill="#9090A8"
                           RadiusX="1" RadiusY="1"
                           HorizontalAlignment="Center"/>
              </StackPanel>
              <Border Name="NotiBadge" IsVisible="False"
                      Background="#EF4444" CornerRadius="6"
                      MinWidth="14" Height="14"
                      HorizontalAlignment="Right" VerticalAlignment="Top"
                      Margin="0,-4,-4,0" Padding="3,0">
                <TextBlock Name="NotiBadgeText" Text="0"
                           FontSize="8" Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Border>
            </Grid>
            <TextBlock Name="NavNotiText" Text="Thông Báo"
                       FontSize="10" Foreground="#9090A8"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

        <!-- Tài Khoản -->
        <Button Grid.Column="3" Classes="nav"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Click="OnNavAccountClick">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center" Spacing="4">
            <StackPanel Name="NavAccIcon"
                        HorizontalAlignment="Center" Spacing="2">
              <Ellipse Width="10" Height="10" HorizontalAlignment="Center">
                <Ellipse.Fill><SolidColorBrush Color="#9090A8"/></Ellipse.Fill>
              </Ellipse>
              <Border Width="16" Height="8" CornerRadius="4,4,0,0"
                      HorizontalAlignment="Center">
                <Border.Background><SolidColorBrush Color="#9090A8"/></Border.Background>
              </Border>
            </StackPanel>
            <TextBlock Name="NavAccText" Text="Tài Khoản"
                       FontSize="10" Foreground="#9090A8"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Button>

      </Grid>
    </Border>

    <!-- ══ MENU OVERLAY ══════════════════════════════════════════════════════ -->
    <Border Name="MenuOverlay" Grid.Row="0" Grid.RowSpan="3"
            IsVisible="False" Background="#60000000"
            PointerPressed="OnMenuOverlayPressed">
      <Border HorizontalAlignment="Left" Width="260" Background="#FFFFFF">
        <StackPanel Margin="24,52,24,0" Spacing="0">
          <TextBlock Text="Menu" FontSize="20" FontWeight="Bold"
                     Foreground="#111122" Margin="0,0,0,24"/>
          <TextBlock Text="(Chưa có nội dung)"
                     FontSize="13" Foreground="#AAAACC"/>
        </StackPanel>
      </Border>
    </Border>

    <!-- ══ PROFILE POPUP ═════════════════════════════════════════════════════ -->
    <Border Name="ProfileOverlay" Grid.Row="0" Grid.RowSpan="3"
            IsVisible="False" Background="Transparent"
            PointerPressed="OnProfileOverlayPressed">
      <Border HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="0,60,12,0" Width="190"
              CornerRadius="12" Background="#FFFFFF"
              BorderBrush="#EBEBF0" BorderThickness="1"
              Padding="0,8">
        <StackPanel Spacing="0">
          <Button Classes="nav" HorizontalAlignment="Stretch"
                  Padding="16,11" Click="OnViewProfileClick">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Border Width="28" Height="28" CornerRadius="14" Background="#F0EDFF">
                <TextBlock Text="👤" FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="Hồ sơ của tôi" FontSize="13"
                         Foreground="#111122" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Border Height="1" Background="#F0F0F5" Margin="16,2"/>
          <Button Classes="nav" HorizontalAlignment="Stretch"
                  Padding="16,11" Click="OnLogoutClick">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Border Width="28" Height="28" CornerRadius="14" Background="#FFF0F0">
                <TextBlock Text="↩" FontSize="14" Foreground="#EF4444"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="Đăng xuất" FontSize="13"
                         Foreground="#EF4444" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>
    </Border>

  </Grid>
</UserControl>