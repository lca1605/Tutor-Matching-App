<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyApp.Views.TutorProfileView">

  <UserControl.Styles>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#1A1A2E"/>
      <Setter Property="Foreground" Value="#E0E0F0"/>
      <Setter Property="BorderBrush" Value="#3A3A5C"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="CaretBrush" Value="#7C6FCD"/>
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#7C6FCD"/>
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#1A1A2E"/>
      <Setter Property="Foreground" Value="#E0E0F0"/>
      <Setter Property="BorderBrush" Value="#3A3A5C"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#7C6FCD"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="0,14"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#6A5DBB"/>
    </Style>
    <Style Selector="Button.primary:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="#3A3A5C"/>
    </Style>
    <Style Selector="Button.outline">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#7C6FCD"/>
      <Setter Property="BorderBrush" Value="#7C6FCD"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.outline:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1A1030"/>
    </Style>
    <Style Selector="Button.link">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#7C6FCD"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.link:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <!-- Teaching mode toggle button -->
    <Style Selector="Button.mode-off">
      <Setter Property="Background" Value="#1A1A2E"/>
      <Setter Property="Foreground" Value="#6B6B8D"/>
      <Setter Property="BorderBrush" Value="#3A3A5C"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="0,10"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.mode-on">
      <Setter Property="Background" Value="#2A1A4A"/>
      <Setter Property="Foreground" Value="#E0E0F0"/>
      <Setter Property="BorderBrush" Value="#7C6FCD"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="0,10"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.mode-off:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1E1E3A"/>
    </Style>
    <Style Selector="Button.mode-on:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2A1A4A"/>
    </Style>
  </UserControl.Styles>

  <Panel>
    <!-- Background -->
    <Border>
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#0D0D1A" Offset="0"/>
          <GradientStop Color="#12122A" Offset="0.5"/>
          <GradientStop Color="#0D0D1A" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- Decorative -->
    <Canvas>
      <Ellipse Canvas.Left="-40" Canvas.Top="200" Width="160" Height="160" Opacity="0.10">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#7C6FCD" Offset="0"/>
            <GradientStop Color="Transparent" Offset="1"/>
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
      <Ellipse Canvas.Left="320" Canvas.Top="500" Width="140" Height="140" Opacity="0.08">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#4FC3F7" Offset="0"/>
            <GradientStop Color="Transparent" Offset="1"/>
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
    </Canvas>

    <!-- Card -->
    <Border Margin="30" CornerRadius="16"
            Background="#12122A"
            BoxShadow="0 20 60 0 #50000000"
            BorderThickness="1">
      <Border.BorderBrush>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#3A3A5C" Offset="0"/>
          <GradientStop Color="#1E1E3A" Offset="1"/>
        </LinearGradientBrush>
      </Border.BorderBrush>

      <Grid RowDefinitions="Auto,*,Auto" Margin="36,28,36,28">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="0">
          <!-- Back + Step -->
          <Grid Margin="0,0,0,16">
            <Button Classes="link" Content="← Quay lại"
                    HorizontalAlignment="Left"
                    Click="OnBackClick"/>
            <!-- Step indicator -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Spacing="8">
              <Grid Width="24" Height="24">
                <Ellipse Width="24" Height="24" Fill="#2A2A40"
                         StrokeThickness="1" Stroke="#3A3A5C"/>
                <TextBlock Text="1" FontSize="11" FontWeight="Bold"
                           Foreground="#4A4A6A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Grid>
              <Rectangle Width="30" Height="2" Fill="#2A2A40" VerticalAlignment="Center"/>
              <Grid Width="24" Height="24">
                <Ellipse Width="24" Height="24">
                  <Ellipse.Fill>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                      <GradientStop Color="#7C6FCD" Offset="0"/>
                      <GradientStop Color="#4FC3F7" Offset="1"/>
                    </LinearGradientBrush>
                  </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="2" FontSize="11" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Grid>
            </StackPanel>
          </Grid>

          <!-- Title -->
          <StackPanel Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="Hồ sơ Gia sư" FontSize="20" FontWeight="Bold"
                       Foreground="#E0E0F0"/>
            <TextBlock Text="Điền thông tin để được admin xét duyệt"
                       FontSize="12" Foreground="#6B6B8D"/>
          </StackPanel>
        </StackPanel>

        <!-- Scrollable form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="0">

            <!-- Họ tên -->
            <TextBlock Text="Họ và tên đầy đủ" FontSize="12"
                       Foreground="#9090B0" Margin="0,0,0,6"/>
            <TextBox Name="FullNameBox" Watermark="Nguyễn Văn A"
                     Margin="0,0,0,16"/>

            <!-- Mô tả -->
            <TextBlock Text="Mô tả bản thân" FontSize="12"
                       Foreground="#9090B0" Margin="0,0,0,6"/>
            <TextBox Name="DescriptionBox"
                     Watermark="Giới thiệu ngắn về bản thân, phong cách dạy..."
                     AcceptsReturn="True"
                     Height="80"
                     TextWrapping="Wrap"
                     Margin="0,0,0,16"/>

            <!-- Nơi làm / học -->
            <TextBlock Text="Nơi làm hoặc học hiện tại" FontSize="12"
                       Foreground="#9090B0" Margin="0,0,0,6"/>
            <TextBox Name="WorkplaceBox"
                     Watermark="VD: Đại học Bách Khoa Hà Nội, Công ty ABC..."
                     Margin="0,0,0,16"/>

            <!-- Ngành nghề -->
            <TextBlock Text="Ngành nghề chính" FontSize="12"
                       Foreground="#9090B0" Margin="0,0,0,6"/>
            <TextBox Name="ProfessionBox"
                     Watermark="VD: Kỹ sư phần mềm, Giáo viên Toán..."
                     Margin="0,0,0,16"/>

            <!-- Bằng cấp -->
            <TextBlock Text="Bằng cấp" FontSize="12"
                       Foreground="#9090B0" Margin="0,0,0,6"/>
            <TextBox Name="DegreeBox"
                     Watermark="VD: Cử nhân CNTT - ĐH Bách Khoa 2020"
                     Margin="0,0,0,16"/>

            <!-- Upload CV -->
            <TextBlock Text="CV (PDF hoặc Word)" FontSize="12"
                       Foreground="#9090B0" Margin="0,0,0,8"/>
            <Border CornerRadius="8" BorderThickness="1" BorderBrush="#3A3A5C"
                    Background="#1A1A2E" Padding="16,12" Margin="0,0,0,16">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Name="CvFileNameText"
                           Text="Chưa chọn file"
                           Foreground="#4A4A6A" FontSize="13"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1" Classes="outline"
                        Content="Chọn file"
                        Click="OnPickCvClick"/>
              </Grid>
            </Border>

            <!-- Môn có thể dạy -->
            <TextBlock Text="Môn học có thể dạy" FontSize="12"
                       Foreground="#9090B0" Margin="0,0,0,8"/>
            <!-- Tag list các môn đã chọn -->
            <WrapPanel Name="SubjectTagPanel" Margin="0,0,0,8"/>
            <!-- ComboBox chọn môn -->
            <ComboBox Name="SubjectComboBox"
                      HorizontalAlignment="Stretch"
                      PlaceholderText="-- Chọn môn học --"
                      Margin="0,0,0,16"
                      SelectionChanged="OnSubjectSelected"/>

            <!-- Lương 1 giờ -->
            <TextBlock Text="Học phí / giờ (VND)" FontSize="12"
                       Foreground="#9090B0" Margin="0,0,0,6"/>
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
              <TextBox Name="HourlyRateBox"
                       Watermark="VD: 150000"
                       Grid.Column="0"/>
              <Border Grid.Column="1"
                      Background="#2A2A40"
                      BorderBrush="#3A3A5C"
                      BorderThickness="1,1,1,1"
                      CornerRadius="0,8,8,0"
                      Padding="12,0"
                      Margin="-1,0,0,0">
                <TextBlock Text="₫/giờ" Foreground="#6B6B8D"
                           FontSize="13" VerticalAlignment="Center"/>
              </Border>
            </Grid>

            <!-- Hình thức dạy -->
            <TextBlock Text="Hình thức dạy học" FontSize="12"
                       Foreground="#9090B0" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Margin="0,0,0,20">
            <Button Name="ModeOnlineBtn"
                    Classes="mode-on"
                    Content="🖥 Online"
                    Width="110"
                    HorizontalContentAlignment="Center"
                    Click="OnModeOnlineClick"/>
            <Button Name="ModeOfflineBtn"
                    Classes="mode-off"
                    Content="🏠 Offline"
                    Width="110"
                    HorizontalContentAlignment="Center"
                    Click="OnModeOfflineClick"/>
            <Button Name="ModeBothBtn"
                    Classes="mode-off"
                    Content="✦ Cả hai"
                    Width="110"
                    HorizontalContentAlignment="Center"
                    Click="OnModeBothClick"/>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>

        <!-- Bottom -->
        <StackPanel Grid.Row="2" Spacing="0" Margin="0,16,0,0">
          <!-- Error -->
          <Border Name="ErrorPanel" IsVisible="False"
                  Background="#2A1520" BorderBrush="#8B2635"
                  BorderThickness="1" CornerRadius="6"
                  Padding="12,8" Margin="0,0,0,12">
            <TextBlock Name="ErrorText" Foreground="#FC5C65"
                       FontSize="12" TextWrapping="Wrap"/>
          </Border>

          <Button Name="SubmitButton" Classes="primary"
                  Content="Hoàn tất đăng ký"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Click="OnSubmitClick"/>
        </StackPanel>

      </Grid>
    </Border>

    <!-- Pending overlay -->
    <Border Name="PendingOverlay" IsVisible="False"
            Background="#CC0D0D1A">
      <Border CornerRadius="16" Background="#12122A"
              BorderThickness="1" BorderBrush="#3A3A5C"
              Padding="40,36"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="320"
              BoxShadow="0 20 60 0 #70000000">
        <StackPanel Spacing="16" HorizontalAlignment="Center">
          <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
          <TextBlock Text="Đang chờ xét duyệt"
                     FontSize="18" FontWeight="Bold"
                     Foreground="#E0E0F0"
                     HorizontalAlignment="Center"/>
          <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                     FontSize="13" Foreground="#9090B0"
                     Text="Hồ sơ của bạn đã được gửi thành công. Admin sẽ xem xét và phê duyệt trong vòng 1–3 ngày làm việc."/>
          <Border Height="1" Background="#2A2A40" Margin="0,4"/>
          <TextBlock Text="Bạn sẽ nhận được thông báo qua email khi hồ sơ được duyệt."
                     TextWrapping="Wrap" TextAlignment="Center"
                     FontSize="12" Foreground="#6B6B8D"/>
          <Button Classes="primary" Content="Về trang đăng nhập"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Margin="0,8,0,0"
                  Click="OnGoToLoginClick"/>
        </StackPanel>
      </Border>
    </Border>

  </Panel>
</UserControl>